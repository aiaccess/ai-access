{
	"name": "ai-access/ai-access",
	"description": "A flexible PHP library providing access to various AI models (Gemini, OpenAI, Anthropic, DeepSeek, Grok) via a consistent interface.",
	"keywords": ["ai", "artificial intelligence", "llm", "large language model", "gemini", "openai", "anthropic", "xai", "grok", "deepseek", "api", "client", "sdk", "generative ai", "chat", "chatbot", "ai access"],
	"keywords": ["composer"],
	"license": ["BSD-3-Clause"],
	"authors": [
		{
			"name": "David Grudl",
			"homepage": "https://davidgrudl.com"
		}
	],
	"require": {
		"php": "^8.1",
		"ext-curl": "*",
		"ext-json": "*"
	},
	"require-dev": {
		"nette/tester": "^2.5",
		"tracy/tracy": "^2.10",
		"phpstan/phpstan": "^2.2@stable",
		"phpstan/extension-installer": "^1.4@stable",
		"nette/phpstan-rules": "^1.0",
		"mockery/mockery": "^1.6",
		"dg/bypass-finals": "^1.9"
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"minimum-stability": "stable",
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	},
	"config": {
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	}
}
